{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chronicle",
  "version": "0.1.0",
  "identifier": "app.chronicle.dev",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Chronicle",
        "width": 1240,
        "height": 900,
        "minWidth": 920,
        "minHeight": 640,
        "decorations": false,
        "shadow": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}