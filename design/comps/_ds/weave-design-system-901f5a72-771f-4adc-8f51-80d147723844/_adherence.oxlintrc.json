    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist Variable|Geist Mono Variable))/i]",
        "message": "Font not provided by the design system. Available: Geist Variable, Geist Mono Variable."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|primary-ghost|ghost|subtle)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'primary-ghost' | 'ghost' | 'subtle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|icon)$/]",
        "message": "<Button> size must be one of 'default' | 'icon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onClose|className|backdropClassName|includeChromeClassName|id|role|ariaLabel|ariaLabelledBy|ariaDescribedBy|closeOnBackdrop|closeOnEscape|layout|as|onSubmit|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: children, onClose, className, backdropClassName, includeChromeClassName, id, role, ariaLabel, ariaLabelledBy, ariaDescribedBy, closeOnBackdrop, closeOnEscape, layout, as, onSubmit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:dialog|alertdialog)$/]",
        "message": "<Dialog> role must be one of 'dialog' | 'alertdialog'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:default|sectioned)$/]",
        "message": "<Dialog> layout must be one of 'default' | 'sectioned'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:div|form)$/]",
        "message": "<Dialog> as must be one of 'div' | 'form'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: className, id, style, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
